rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Check if the requesting user is an admin (role stored in their Firestore profile)
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if requesting user is a coach
    function isCoach() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coach';
    }

    // Check if requesting user is an employer
    function isEmployer() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employer';
    }

    // Check if requesting user is a student
    function isStudent() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // ============================================
    // API CACHE (Shared across all users)
    // ============================================
    match /api_cache/{document} {
      // Anyone can read cache (public data, shared across users)
      allow read: if true;

      // Only authenticated users can write/update cache
      // This allows the first visitor to populate cache
      // In production with Cloud Functions, restrict to service account only
      allow write: if request.auth != null;
    }

    // ============================================
    // USERS
    // ============================================
    match /users/{userId} {
      // Users can read their own profile; admins can read all profiles
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());

      // Users can create/update their own profile; admins can update any
      allow write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());

      // ── Job Applications subcollection (Job Tracker) ──
      // Strict isolation: only the owning user can read/write their own applications
      match /applications/{applicationId} {
        allow read, write: if request.auth != null &&
          request.auth.uid == userId;
      }
    }
    
    // ============================================
    // OPPORTUNITIES (Job Listings)
    // ============================================
    match /opportunities/{opportunityId} {
      // Anyone can read job listings (public)
      allow read: if true;

      // Only authenticated users (employers) can create jobs
      allow create: if request.auth != null;

      // Job owner or admin can update/delete
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.employerId ||
        request.auth.uid == resource.data.created_by ||
        isAdmin()
      );
    }
    
    // ============================================
    // APPLICATIONS
    // ============================================
    match /applications/{applicationId} {
      // Students can read their own; employers can read applications for their jobs; admins read all
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.employerId ||
        isAdmin()
      );

      // Any authenticated user can create applications
      allow create: if request.auth != null;

      // Students can update their own; employers can update status; admins update any
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == resource.data.employerId ||
        isAdmin()
      );
    }
    
    // ============================================
    // SAVED JOBS
    // ============================================
    match /saved_jobs/{savedJobId} {
      // Users can read their own saved jobs
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.user_id;
      
      // Users can save jobs
      allow create: if request.auth != null;
      
      // Users can delete their own saved jobs
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.user_id;
    }
    
    // ============================================
    // EVENTS
    // ============================================
    match /events/{eventId} {
      // Anyone can read events (public)
      allow read: if true;
      
      // Only authenticated users (admins) can create events
      allow create: if request.auth != null;
      
      // Only event owner can update/delete
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.created_by;
    }
    
    // ============================================
    // EVENT REGISTRATIONS
    // ============================================
    match /eventRegistrations/{registrationId} {
      // Users can read their own registrations
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.user_id;
      
      // Users can create registrations
      allow create: if request.auth != null;
      
      // Admins can read all registrations
      allow read: if request.auth != null;
    }
    
    // ============================================
    // COACHING SESSIONS
    // ============================================
    match /coachingSessions/{sessionId} {
      // Students can read their own bookings; coaches can read sessions they own;
      // admins can read all
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.coachId ||
        isAdmin()
      );

      // Any authenticated user can create a session booking
      allow create: if request.auth != null;

      // Coaches can update their own sessions; admins can update any
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.coachId ||
        isAdmin()
      );

      // Only admins can delete sessions
      allow delete: if isAdmin();
    }
    
    // ============================================
    // VIDEO PITCHES
    // ============================================
    match /video_pitches/{pitchId} {
      // Public pitches can be read by anyone (for sharing)
      allow read: if resource.data.is_public == true;
      
      // Users can read their own pitches
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.user_id;
      
      // Users can create pitches
      allow create: if request.auth != null;
      
      // Users can update their own pitches
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.user_id;
    }
    
    // ============================================
    // CV OPTIMIZATIONS
    // ============================================
    match /cv_optimizations/{optimizationId} {
      // Users can read their own optimizations
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.user_id;
      
      // Users can create optimizations
      allow create: if request.auth != null;
    }
    
    // ============================================
    // PURCHASE HISTORY
    // ============================================
    match /purchase_history/{purchaseId} {
      // Users can read their own purchase history
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.user_id;
      
      // Users can create purchase records
      allow create: if request.auth != null;
    }
    
    // ============================================
    // API USAGE LOGS (Optional monitoring)
    // ============================================
    match /api_usage_logs/{logId} {
      // Anyone can write logs (for monitoring)
      allow create: if true;
      
      // Only admins can read logs
      allow read: if request.auth != null;
    }
    
    // ============================================
    // TALENT MATCHES (AI Matching Engine)
    // ============================================
    match /talent_matches/{matchId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.employerId ||
        request.auth.uid == resource.data.candidateId ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.employerId ||
        isAdmin()
      );
    }

    // ============================================
    // TALENT PIPELINES
    // ============================================
    match /talent_pipelines/{pipelineId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.employerId ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.employerId ||
        isAdmin()
      );

      // Pipeline candidates subcollection
      match /candidates/{candidateDocId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
      }
    }

    // ============================================
    // OUTREACH CAMPAIGNS
    // ============================================
    match /outreach_campaigns/{campaignId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.ownerId ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerId ||
        isAdmin()
      );

      // Campaign recipients subcollection
      match /recipients/{recipientId} {
        allow read, write: if request.auth != null;
      }
    }

    // ============================================
    // OUTREACH LOG
    // ============================================
    match /outreach_log/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // ============================================
    // BILLING EVENTS (Revenue Tracking)
    // ============================================
    match /billing_events/{eventId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.employerId ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if isAdmin();
    }

    // ============================================
    // JOBS (Synced from external APIs by Cloud Function)
    // ============================================
    match /jobs/{jobId} {
      // All authenticated users can read synced job listings
      allow read: if request.auth != null;

      // Only admins can manually create/update/delete
      // (Cloud Functions use Admin SDK which bypasses rules)
      allow write: if isAdmin();
    }

    // ============================================
    // JOB ROLE TAXONOMY (Shared reference data)
    // ============================================
    match /job_roles/{roleId} {
      // All authenticated users can read the taxonomy
      allow read: if request.auth != null;

      // Only admins can create/update/delete taxonomy entries
      allow write: if isAdmin();

      // Nested functions and levels
      match /functions/{functionId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
      }
    }

    // ============================================
    // GLOBAL STATS (Read-only aggregate counters)
    // ============================================
    match /global_stats/{statId} {
      // All authenticated users can read global stats
      // (e.g. total applications, popular industries, avg time-to-offer)
      allow read: if request.auth != null;

      // Only admins (or Cloud Functions) can write stats
      // In production, restrict to service account only
      allow write: if isAdmin();
    }

    // ============================================
    // JOB APPLICATIONS (Job Tracker — saved/applied jobs)
    // ============================================
    match /job_applications/{applicationId} {
      // Users can read their own tracked applications
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;

      // Any authenticated user can create a tracked application
      allow create: if request.auth != null;

      // Users can update their own tracked applications (status changes)
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // ============================================
    // JOB CLICKS (Analytics tracking)
    // ============================================
    match /job_clicks/{clickId} {
      // Users can read their own click history
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;

      // Any authenticated user can log a click
      allow create: if request.auth != null;

      // Allow updating click records (e.g. marking as applied)
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // ============================================
    // AI APPLIER PREFERENCES
    // ============================================
    match /ai_applier_prefs/{userId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == userId;
    }

    // ============================================
    // AI APPLICATIONS (Legacy queue)
    // ============================================
    match /ai_applications/{applicationId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // ============================================
    // TAILORED APPLICATIONS (AI Concierge)
    // ============================================
    match /tailored_applications/{applicationId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // ============================================
    // DENY ALL OTHER ACCESS
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
